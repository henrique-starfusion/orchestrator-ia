{
  "maximum_iterations": 3,
  "same_issue_repeat_limit": 2,
  "minimum_validation_score": 0.9,
  "minimum_score_improvement": 0.03,
  "maximum_duration_seconds": 3600,
  "agent_timeout_default_s": 1800,
  "agent_timeout_by_role": {
    "planner": 900,
    "executor": 2400,
    "corrector": 2400,
    "validator": 1200,
    "tester": 600,
    "skill_selector": 120
  },
  "require_independent_validation": true,
  "require_deterministic_validation": true,
  "require_documentation_review": true,
  "allow_parallel_read_only_analysis": true,
  "allow_parallel_workspace_writes": false,
  "documentation_policy": {
    "required_before_completion": true,
    "message": "Ao final de cada tarefa, revisar e atualizar a documentacao afetada antes da conclusao."
  },
  "skill_selection": {
    "enabled": true,
    "model_tier": "fast",
    "max_skills": 5,
    "timeout_s": 120,
    "include_user_global": true
  },
  "context_compaction": {
    "enabled": true,
    "save_learning_before_compact": true,
    "digest_max_chars": 1500,
    "truncate_result_artifacts_chars": 20000,
    "update_wolf_status": true
  },
  "token_economy": {
    "enabled": true,
    "caveman_enabled": true,
    "caveman_default": "full",
    "model_routing": "config/models.json",
    "forbid_max_tier_for": ["trivial", "classify", "docs", "documentation"],
    "require_task_class_before_call_agent": true,
    "required_agent_tooling": {
      "openwolf": {
        "always_on": true,
        "files": [".wolf/STATUS.md", ".wolf/cerebrum.md", ".wolf/anatomy.md"],
        "instruction": "Leia .wolf/STATUS.md ANTES de qualquer ação; consulte .wolf/cerebrum.md (Do-Not-Repeat) antes de gerar código; use .wolf/anatomy.md como índice de arquivos."
      },
      "graphify": {
        "always_on": true,
        "condition": ".codegraph/ exists",
        "instruction": "Se .codegraph/ existir, use `codegraph explore` para localizar símbolos antes de ler arquivos."
      },
      "superpowers": {
        "always_on": true,
        "entry_skill": "using-superpowers",
        "instruction": "Invoque a skill `using-superpowers` antes de qualquer ação; use as skills listadas em 'Skills selecionadas' (0.4.13); não invoque skills fora dessa lista."
      },
      "caveman": {
        "always_on": true,
        "intensity": "full",
        "instruction": "Prosa concisa sem artigos/enchimento. NUNCA abreviar JSON, logs, erros, planos, docs ou código."
      }
    }
  }
}
