{
  "version": "0.2.0",
  "description": "Ferramentas, MCPs, plugins e skills instalados no perfil do usuario (globais), reutilizaveis em qualquer projeto.",
  "npm_globals": [
    {
      "id": "openwolf",
      "package": "openwolf",
      "check_command": "openwolf",
      "required": false
    },
    {
      "id": "firecrawl-cli",
      "package": "firecrawl-cli",
      "check_command": "firecrawl",
      "required": false
    }
  ],
  "uv_tools": [
    {
      "id": "graphify",
      "package": "graphifyy",
      "check_command": "graphify",
      "post_install": ["install"],
      "notes": "CLI + MCP em ~/.local/bin; post_install sincroniza skill do usuario"
    }
  ],
  "mcp_servers": [
    {
      "id": "context7",
      "name": "Context7",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "clients": ["claude", "cursor"]
    },
    {
      "id": "playwright",
      "name": "Playwright",
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "clients": ["claude", "cursor", "codex"]
    },
    {
      "id": "sequential-thinking",
      "name": "Sequential Thinking",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking@latest"],
      "clients": ["claude", "cursor"]
    }
  ],
  "claude_plugins": [
    "context7@claude-plugins-official",
    "playwright@claude-plugins-official",
    "superpowers@claude-plugins-official",
    "skill-creator@claude-plugins-official",
    "atlassian@claude-plugins-official",
    "frontend-design@claude-plugins-official",
    "caveman@caveman"
  ],
  "skill_packages": [
    {
      "id": "superpowers",
      "source": "obra/superpowers",
      "notes": "using-superpowers + workflow skills"
    },
    {
      "id": "find-skills",
      "source": "vercel-labs/skills",
      "notes": "descoberta de skills"
    },
    {
      "id": "firecrawl",
      "source": "firecrawl/cli",
      "notes": "hub Firecrawl + variantes CLI"
    },
    {
      "id": "terraform-skill",
      "source": "antonbabenko/terraform-skill",
      "notes": "Terraform/OpenTofu best practices (Anton Babenko, 2.2k stars, ativo). Instala via npx skills add; alternativa gerenciada: marketplace antonbabenko/agent-plugins"
    },
    {
      "id": "caveman",
      "source": "juliusbrussee/caveman",
      "notes": "modo caveman — ~75% menos tokens de prosa"
    }
  ]
}
