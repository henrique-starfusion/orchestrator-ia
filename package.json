{
  "name": "@starfusion/orchestrator",
  "version": "0.4.10",
  "description": "Orquestrador IA Multiagente (StarFusion): instalador, runtime e MCP Cursor. Fonte canônica .orchestrator/",
  "license": "MIT",
  "author": "Henrique Rodrigues <StarFusion Consultoria, Tecnologia e Soluções em Informática LTDA.>",
  "homepage": "https://github.com/henrique-starfusion/orchestrator-ia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrique-starfusion/orchestrator-ia.git"
  },
  "bugs": {
    "url": "https://github.com/henrique-starfusion/orchestrator-ia/issues"
  },
  "bin": {
    "orchestrator": "bin/orchestrator.js",
    "mao": "bin/orchestrator.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "package/",
    "runtime/",
    "docs/",
    "VERSION",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "orchestrator-ia.bat",
    "install.ps1",
    "get.ps1"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "multiagent",
    "orchestrator",
    "claude",
    "codex",
    "agents",
    "starfusion",
    "bootstrap"
  ],
  "scripts": {
    "test": "powershell -NoProfile -ExecutionPolicy Bypass -File tests/Run-AllTests.ps1",
    "test:runtime": "python -m pytest -q runtime/tests",
    "test:all": "npm test && npm run test:runtime"
  },
  "preferGlobal": true
}
